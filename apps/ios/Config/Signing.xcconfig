// Shared iOS signing defaults for local development + CI.
#include "Version.xcconfig"

OPNEX_IOS_DEFAULT_TEAM = Y5PE65HELJ
OPNEX_IOS_SELECTED_TEAM = $(OPNEX_IOS_DEFAULT_TEAM)
OPNEX_DEVELOPMENT_TEAM = $(OPNEX_IOS_SELECTED_TEAM)
OPNEX_CODE_SIGN_STYLE = Automatic
OPNEX_APP_BUNDLE_ID = ai.opnex.client
OPNEX_WATCH_APP_BUNDLE_ID = ai.opnex.client.watchkitapp
OPNEX_WATCH_EXTENSION_BUNDLE_ID = ai.opnex.client.watchkitapp.extension
OPNEX_ACTIVITY_WIDGET_BUNDLE_ID = ai.opnex.client.activitywidget
OPNEX_WATCH_APP_PROFILE =
OPNEX_WATCH_EXTENSION_PROFILE =

// Local contributors can override this by running scripts/ios-configure-signing.sh.
// Keep include after defaults: xcconfig is evaluated top-to-bottom.
#include? "../.local-signing.xcconfig"
#include? "../LocalSigning.xcconfig"

CODE_SIGN_STYLE = $(OPNEX_CODE_SIGN_STYLE)
CODE_SIGN_IDENTITY = Apple Development
DEVELOPMENT_TEAM = $(OPNEX_DEVELOPMENT_TEAM)

// Let Xcode manage provisioning for the selected local team unless a local override pins one.
PROVISIONING_PROFILE_SPECIFIER =
