// Default signing values for shared/repo builds.
// Auto-selected local team overrides live in .local-signing.xcconfig (git-ignored).
// Manual local overrides can go in LocalSigning.xcconfig (git-ignored).

#include "Config/Version.xcconfig"

OPNEX_CODE_SIGN_STYLE = Manual
OPNEX_DEVELOPMENT_TEAM = Y5PE65HELJ

OPNEX_APP_BUNDLE_ID = ai.opnex.client
OPNEX_SHARE_BUNDLE_ID = ai.opnex.client.share
OPNEX_WATCH_APP_BUNDLE_ID = ai.opnex.client.watchkitapp
OPNEX_WATCH_EXTENSION_BUNDLE_ID = ai.opnex.client.watchkitapp.extension
OPNEX_ACTIVITY_WIDGET_BUNDLE_ID = ai.opnex.client.activitywidget

OPNEX_APP_PROFILE = ai.opnex.client Development
OPNEX_SHARE_PROFILE = ai.opnex.client.share Development

// Keep local includes after defaults: xcconfig is evaluated top-to-bottom,
// so later assignments in local files override the defaults above.
#include? ".local-signing.xcconfig"
#include? "LocalSigning.xcconfig"
