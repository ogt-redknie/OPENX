{
  "name": "@opnex/synology-chat",
  "version": "2026.4.25",
  "description": "Synology Chat channel plugin for OPNEX",
  "type": "module",
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@opnex/plugin-sdk": "workspace:*"
  },
  "opnex": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "synology-chat",
      "label": "Synology Chat",
      "selectionLabel": "Synology Chat (Webhook)",
      "docsPath": "/channels/synology-chat",
      "docsLabel": "synology-chat",
      "blurb": "Connect your Synology NAS Chat to OPNEX with full agent capabilities.",
      "order": 90
    },
    "install": {
      "npmSpec": "@opnex/synology-chat",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    }
  }
}
