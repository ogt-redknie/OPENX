{
  "name": "@opnex/mattermost",
  "version": "2026.4.25",
  "description": "OPNEX Mattermost channel plugin",
  "type": "module",
  "dependencies": {
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@opnex/plugin-sdk": "workspace:*",
    "opnex": "workspace:*"
  },
  "peerDependencies": {
    "opnex": ">=2026.4.25"
  },
  "peerDependenciesMeta": {
    "opnex": {
      "optional": true
    }
  },
  "opnex": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "mattermost",
      "label": "Mattermost",
      "selectionLabel": "Mattermost (plugin)",
      "docsPath": "/channels/mattermost",
      "docsLabel": "mattermost",
      "blurb": "self-hosted Slack-style chat; install the plugin to enable.",
      "order": 65
    },
    "install": {
      "npmSpec": "@opnex/mattermost",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    }
  }
}
