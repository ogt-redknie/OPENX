{
  "name": "@opnex/memory-lancedb",
  "version": "2026.4.25",
  "description": "OPNEX LanceDB-backed long-term memory plugin with auto-recall/capture",
  "type": "module",
  "dependencies": {
    "@lancedb/lancedb": "^0.27.2",
    "openai": "^6.34.0",
    "typebox": "1.1.33"
  },
  "devDependencies": {
    "@opnex/plugin-sdk": "workspace:*"
  },
  "opnex": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@opnex/memory-lancedb",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.4.25"
    },
    "build": {
      "opnexVersion": "2026.4.25"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
