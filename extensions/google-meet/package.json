{
  "name": "@opnex/google-meet",
  "version": "2026.4.25",
  "description": "OPNEX Google Meet participant plugin",
  "type": "module",
  "dependencies": {
    "commander": "^14.0.3",
    "typebox": "1.1.33"
  },
  "devDependencies": {
    "@opnex/plugin-sdk": "workspace:*",
    "opnex": "workspace:*"
  },
  "peerDependencies": {
    "opnex": ">=2026.4.25"
  },
  "peerDependenciesMeta": {
    "opnex": {
      "optional": true
    }
  },
  "opnex": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "minHostVersion": ">=2026.4.20"
    },
    "compat": {
      "pluginApi": ">=2026.4.25"
    },
    "build": {
      "opnexVersion": "2026.4.25"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
